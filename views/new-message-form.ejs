<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Nova Mensagem | Members Only</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 h-screen flex items-center justify-center">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-lg">
        <div class="mb-4">
            <a href="/" class="text-sm text-gray-400 hover:text-indigo-600 flex items-center transition">← Voltar</a>
        </div>
        <h2 class="text-3xl font-extrabold text-indigo-600 mb-6">Falar no Clube</h2>
        
        <form action="/messages/new" method="POST" class="space-y-4">
            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase">Assunto</label>
                <input type="text" name="title" required class="w-full px-4 py-2 border rounded-xl outline-none focus:ring-2 focus:ring-indigo-400">
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase">Mensagem</label>
                <textarea name="text" rows="4" required class="w-full px-4 py-2 border rounded-xl outline-none focus:ring-2 focus:ring-indigo-400"></textarea>
            </div>
            <button type="submit" class="w-full bg-indigo-600 text-white font-bold py-3 rounded-xl hover:bg-indigo-700 transition shadow-lg">
                Lançar Mensagem
            </button>
        </form>
    </div>
</body>
</html>