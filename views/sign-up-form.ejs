<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up | Members Only</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 h-screen flex items-center justify-center">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md border border-gray-200">
        <div class="mb-4">
    <a href="/" class="text-sm text-gray-400 hover:text-indigo-600 flex items-center transition">
        ← Voltar para o início
    </a>
</div>
        <h2 class="text-3xl font-extrabold text-indigo-600 mb-6 text-center">Criar Conta</h2>
        
        <% if (errors && errors.length > 0) { %>
            <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6">
                <ul class="text-sm text-red-700">
                    <% errors.forEach(error => { %>
                        <li>⚠️ <%= error.msg %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>

        <form action="/auth/sign-up" method="POST" class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase">Primeiro Nome</label>
                    <input type="text" name="firstName" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-400 outline-none">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase">Sobrenome</label>
                    <input type="text" name="lastName" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-400 outline-none">
                </div>
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase">Email (Username)</label>
                <input type="email" name="username" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-400 outline-none">
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase">Senha</label>
                <input type="password" name="password" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-400 outline-none">
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase">Confirmar Senha</label>
                <input type="password" name="confirmPassword" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-indigo-400 outline-none">
            </div>
            <button type="submit" class="w-full bg-indigo-600 text-white font-bold py-3 rounded-lg hover:bg-indigo-700 transition shadow-lg">
                Cadastrar no Clube
            </button>
        </form>
        <p class="mt-4 text-center text-sm text-gray-500">
            Já é membro? <a href="/auth/log-in" class="text-indigo-600 hover:underline">Entre aqui</a>
        </p>
    </div>
</body>
</html>