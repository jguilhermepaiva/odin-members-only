<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join the Club | Members Only</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 h-screen flex items-center justify-center">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md border border-red-100">
        <h2 class="text-3xl font-extrabold text-red-600 mb-2">Área Administrativa</h2>
        <p class="text-gray-500 text-sm mb-6">Digite o código de mestre para obter o martelo de exclusão.</p>

        <% if (errors.length > 0) { %>
            <p class="text-red-500 text-sm mb-4">❌ <%= errors[0].msg %></p>
        <% } %>

        <form action="/auth/admin" method="POST" class="space-y-4">
            <input type="password" name="passcode" placeholder="Código de Admin" required 
                class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-400 outline-none">
            <button type="submit" class="w-full bg-red-600 text-white font-bold py-3 rounded-lg hover:bg-red-700 transition shadow-lg">
                Garantir Privilégios
            </button>
        </form>
    </div>
</body>
</html>